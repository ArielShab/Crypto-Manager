<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Crypto Manager</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
      crossorigin="anonymous"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
      crossorigin="anonymous"
    ></script>

    <link rel="stylesheet" href="SCSS/style.css" />
    <script defer src="JavaScript/index.js"></script>
  </head>
  <body>
    <div id="app-div" class="app d-flex flex-column min-vh-100 bg-dark">
      <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container-fluid">
          <button
            class="navbar-toggler bg-light"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNavAltMarkup"
            aria-controls="navbarNavAltMarkup"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav">
              <a class="nav-link me-3 bg-secondary rounded" href="index"
                >Home</a
              >
              <a class="nav-link me-3" href="coins">Coins</a>
              <a class="nav-link me-3" href="about">About</a>
              <% if(!logged) { %>
              <a class="nav-link me-3" href="registration">Registration</a>
              <% } else { %>
              <a class="nav-link me-3" href="favorites">Favorites</a>
              <% } %>
            </div>
          </div>
          <% if(!logged) { %>
          <div id="login-div">
            <button class="login-button">Login</button>
            <div id="login-box">
              <form>
                <div class="mt-4">
                  <input
                    type="email"
                    name="email"
                    class="form-control mb-3"
                    id="login-box-email"
                    aria-describedby="emailHelp"
                    placeholder="Enter Email"
                  />
                  <input
                    type="password"
                    name="password"
                    class="form-control"
                    id="login-box-password"
                    placeholder="Enter Password"
                  />
                </div>
                <button
                  id="submit-login"
                  type="submit"
                  class="btn btn-dark mt-2"
                >
                  Submit
                </button>
              </form>
            </div>
          </div>
          <% } else { %>
          <div id="logout-div">
            <button class="logout-button">Logout</button>
          </div>
          <% } %>
        </div>
      </nav>

      <main class="flex-fill text-light d-flex align-items-center">
        <div id="main-div">
          <div id="main-title"><%= title %></div>
          <div class="buttons">
            <% if(!logged) { %>

            <button id="get-started-btn">Get Started</button>
            <button class="login-button">Login</button>
            <% } else { %>
            <button id="favorites-btn">Favorites</button>
            <button class="logout-button">Logout</button>
            <% } %>
          </div>
        </div>
      </main>
      <footer
        id="footer"
        class="container-fluid d-flex align-items-center justify-content-center"
      >
        <div class="text-light">
          &copy All the rights are saved to Ariel Shabtiev
        </div>
      </footer>
    </div>
  </body>
</html>
